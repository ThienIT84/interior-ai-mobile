# ============================================
# Platform-specific auto-generated files
# (Added to prevent committing Flutter-generated platform code)
# ============================================

# Android platform files (auto-generated by Flutter)
android/.gitignore
android/app/build.gradle.kts
android/app/src/debug/
android/app/src/main/AndroidManifest.xml
android/app/src/main/kotlin/
android/app/src/main/res/drawable*/
android/app/src/main/res/values*/
android/app/src/profile/
android/build.gradle.kts
android/gradle.properties
android/gradle/wrapper/
android/settings.gradle.kts

# iOS platform files (auto-generated by Flutter)
ios/.gitignore
ios/Flutter/
ios/Runner.xcodeproj/
ios/Runner.xcworkspace/
ios/Runner/AppDelegate.swift
ios/Runner/Assets.xcassets/
ios/Runner/Base.lproj/
ios/Runner/Info.plist
ios/Runner/Runner-Bridging-Header.h
ios/RunnerTests/

# Linux platform files (auto-generated by Flutter)
linux/.gitignore
linux/CMakeLists.txt
linux/flutter/
linux/runner/

# macOS platform files (auto-generated by Flutter)
macos/.gitignore
macos/Flutter/
macos/Runner.xcodeproj/
macos/Runner.xcworkspace/
macos/Runner/
macos/RunnerTests/

# Windows platform files (auto-generated by Flutter)
windows/.gitignore
windows/CMakeLists.txt
windows/flutter/
windows/runner/

# Web platform files (auto-generated by Flutter)
web/index.html
web/manifest.json

# Test files (auto-generated)
test/widget_test.dart

